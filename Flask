from flask import Flask
app = Flask(__name__)

@app.route('/')
def home():
    return "Hello,World!"

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=5000)

def run_app():
    app.run(debug=True, user_reloader=False, host='0.0.0.0', port=5000)

thread = thread(target=run_app)
thread.start()